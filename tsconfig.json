{
  "compilerOptions": {
    // General
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "target": "ES2020",
    // Modules
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    // Type Checking & Safety
    "strict": true,
    "types": [
      "vite/client",
      "node"
    ],
    "forceConsistentCasingInFileNames": true,
  }
}
